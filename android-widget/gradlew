#

APP_HOME=`dirname "$0"`
APP_HOME=`cd "$APP_HOME" && pwd -P`

JAVACMD="${JAVA_HOME:+$JAVA_HOME/bin/}java"
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

exec "$JAVACMD" $JAVA_OPTS \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain "$@"
